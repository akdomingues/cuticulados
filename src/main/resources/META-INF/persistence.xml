<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="cuticulados" transaction-type="RESOURCE_LOCAL">
        <!-- lista das entidades jpa do projeto -->
        <class>org.cuticulados.pm.entity.Usuario</class>
        <class>org.cuticulados.pm.entity.Profissional</class>
        <class>org.cuticulados.pm.entity.Cliente</class>
        <class>org.cuticulados.pm.entity.Servico</class>
        <class>org.cuticulados.pm.entity.ServicoProduto</class>
        <class>org.cuticulados.pm.entity.Produto</class>
        <class>org.cuticulados.pm.entity.Agendamento</class>
        <class>org.cuticulados.pm.entity.AgendamentoServico</class>
        <class>org.cuticulados.pm.entity.VendaAvulsa</class>
        <class>org.cuticulados.pm.entity.TransacaoFinanceira</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- driver do postgreesql e url, user e senha para conexão com o banco de dados local-->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5433/cuticulados"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="postgres"/>

            <!--hibernate conversor, ele pega a nossa escrita tipo usuario e coloca na linguagem postgresql,
            ele pega os comandos e fala o toma ai, transforme isso em sql so que para o postgresql, ja que,
            postgresql é diferente do mysql e afins-->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <!--"none" pois o flyway vai criar os comandos, create table, alter table e afins-->
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.connection.pool_size" value="5"/>
        </properties>
    </persistence-unit>
</persistence>